# FinovaBank Backend Environment Variables
# Copy this file to .env and update with your actual values
# Usage: cp .env.example .env  then edit .env

# ===============================================
# Eureka Server Configuration
# ===============================================
EUREKA_HOSTNAME=eureka-server
EUREKA_USERNAME=eureka-user
EUREKA_PASSWORD=change-me-in-production
EUREKA_URL=http://eureka-server:8001/eureka/
EUREKA_ENABLED=true

# ===============================================
# Database Configuration (PostgreSQL)
# ===============================================
DB_URL=jdbc:postgresql://postgres:5432/finovabank
DB_HOST=postgres
DB_PORT=5432
DB_NAME=finovabank
DB_USERNAME=finova_user
DB_PASSWORD=change-me-in-production
DB_DRIVER=org.postgresql.Driver

# ===============================================
# Redis Configuration
# ===============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===============================================
# JWT Security Configuration
# ===============================================
# IMPORTANT: Use a strong, random secret key (minimum 64 bytes / 512 bits for HS512)
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-secure-random-string-minimum-64-bytes-long-for-hs512-algorithm-use-openssl-rand
JWT_EXPIRATION=3600000

# ===============================================
# Kafka Configuration
# ===============================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ===============================================
# Email/Mail Configuration (Notification Service)
# ===============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=noreply@finovabank.com

# ===============================================
# Application Profiles
# ===============================================
# Use 'default' for Docker (PostgreSQL), 'dev' for local (H2)
SPRING_PROFILES_ACTIVE=default

# ===============================================
# Logging Configuration
# ===============================================
LOG_LEVEL=INFO

# ===============================================
# Python Services (AI & Compliance)
# ===============================================
AI_SECRET_KEY=change-me-ai-service-secret-key
COMPLIANCE_SECRET_KEY=change-me-compliance-service-secret-key
FLASK_DEBUG=false
