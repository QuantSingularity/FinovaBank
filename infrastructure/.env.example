# FinovaBank Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USER=postgres
# Generate with: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_strong_password_here

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=finovamongo
# Generate with: openssl rand -base64 32
MONGO_ROOT_PASSWORD=CHANGE_ME_strong_password_here

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_strong_password_here

# ─── JWT (MUST be >= 64 bytes / 512 bits for HS512) ───────────────────────────
# Generate with: openssl rand -base64 88
JWT_SECRET=CHANGE_ME_minimum_64_bytes_512_bits_secret_key_for_hs512_algorithm_here_replace_this

# ─── Encryption (MUST be exactly 32 bytes / 256 bits for AES-256) ─────────────
# Generate with: openssl rand -base64 32 | head -c 32
ENCRYPTION_KEY=CHANGE_ME_exactly_32bytes_aes256k

# ─── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_URI=http://vault:8200
# Dev mode only - replace with Kubernetes auth in production
VAULT_DEV_ROOT_TOKEN=dev-only-token-replace-in-prod
VAULT_TRUSTSTORE_PASSWORD=CHANGE_ME

# ─── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Generate with: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# ─── AWS (only if not using IAM instance profiles) ────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2

# ─── Spring Boot ───────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker
